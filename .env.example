# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=

# App URL (production domain — used for payment redirects & webhooks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: display FX rate (KES per 1 USD)
NEXT_PUBLIC_KES_PER_USD=129

# Payments — set PAYMENTS_SANDBOX=true for local dev without provider keys
PAYMENTS_SANDBOX=false

# M-Pesa Daraja
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=https://your-domain.com/api/webhooks/mpesa

# Card (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Crypto (Coinbase Commerce or generic webhook)
CRYPTO_PAYMENTS_API_KEY=
CRYPTO_WEBHOOK_SECRET=
CRYPTO_PAYMENTS_PROVIDER=coinbase_commerce
